# Développement local uniquement — toutes les valeurs sont fictives.
POSTGRES_DB=eblon
POSTGRES_USER=eblon
POSTGRES_PASSWORD=replace-with-a-local-password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://eblon:replace-with-a-local-password@127.0.0.1:5432/eblon
DATABASE_SCHEMA=eblon_bibliotheque
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
TRUSTED_ORIGINS=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
PORT=3000
HOSTNAME=0.0.0.0
PUBLIC_SIGNUP_ENABLED=true
EMAIL_ENABLED=false
RESEND_API_KEY=
EMAIL_FROM=
# Le seed exige cette activation et reste toujours interdit en production.
ALLOW_DEV_SEED=true
# Variables ponctuelles de pnpm admin:bootstrap (ne jamais les conserver en UAT).
BOOTSTRAP_ADMIN_EMAIL=admin@example.invalid
BOOTSTRAP_ADMIN_NAME=Administrateur Exemple
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-temporary-password
