# Copier hors du dépôt vers /opt/blon/bibliotheque/runtime/app.env.
# Valeurs factices uniquement. Les secrets UAT viendront de SSM Parameter Store SecureString.
POSTGRES_DB=eblon_bibliotheque
POSTGRES_USER=eblon_bibliotheque
POSTGRES_PASSWORD=replace-at-deployment
DATABASE_URL=postgresql://eblon_bibliotheque:replace-at-deployment@postgres:5432/eblon_bibliotheque
DATABASE_SCHEMA=eblon_bibliotheque
BETTER_AUTH_URL=https://uat.biblio.blon-enterprises.com
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
TRUSTED_ORIGINS=https://uat.biblio.blon-enterprises.com
NEXT_PUBLIC_APP_URL=https://uat.biblio.blon-enterprises.com
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0
PUBLIC_SIGNUP_ENABLED=false
EMAIL_ENABLED=false
RESEND_API_KEY=
EMAIL_FROM=
